model AstrologerChatSession {
  id                Int               @id @default(autoincrement())
  userId            Int
  astrologerId      Int
  serviceId         Int?
  pricePerMinute    Float
  currency          String            @default("INR")
  currencySymbol    String            @default("₹")
  status            ChatSessionStatus @default(PENDING)

  requestedAt       DateTime          @default(now())
  acceptedAt        DateTime?
  startedAt         DateTime?
  pausedAt          DateTime?
  pauseGraceExpiry  DateTime?
  endedAt           DateTime?
  endReason         String?

  minutesBilled     Int               @default(0)
  /// Actual seconds billed — used for the partial-minute proration on
  /// session end so a 3:10 session charges for the extra 10 seconds
  /// instead of rounding them away. totalCharged is always authoritative
  /// but secondsBilled lets the UI show "3m 10s" accurately.
  secondsBilled     Int               @default(0)
  totalCharged      Float             @default(0)
  gstAmount         Float             @default(0)
  astrologerEarning Float             @default(0)
  adminEarning      Float             @default(0)
  lastTickAt        DateTime?

  /// Free-offer snapshot captured at accept time. If a paid astrologer
  /// ran a "first N minutes free" offer, `freeMinutesGranted` holds
  /// the N; tickBilling skips charges while `secondsBilled` is inside
  /// that window. `freeOfferId` links back to the offer for reporting.
  freeMinutesGranted Int              @default(0)
  freeOfferId        Int?
  freeOffer          AstrologerFreeOffer? @relation(fields: [freeOfferId], references: [id])

  user              User              @relation(fields: [userId], references: [id])
  astrologer        AstrologerAccount @relation(fields: [astrologerId], references: [id])
  messages          AstrologerChatMessage[]
  review            AstrologerReview?

  @@index([userId])
  @@index([astrologerId])
  @@index([status])
}

/// Astrologer-specific free-minutes offer (e.g. "first 2 minutes
/// free, then ₹30/min"). Spawned from an approved Profile Edit
/// Request of section "Free sessions offer" — the request's
/// `freeOffer` payload maps directly into these columns. Per-user
/// consumption tracked via AstrologerFreeOfferUsage so a single
/// offer can cap uses across the shopper base without allowing
/// abuse (repeatedly claiming the free tier from the same user).
model AstrologerFreeOffer {
  id                 Int       @id @default(autoincrement())
  astrologerId       Int
  title              String
  description        String?
  /// "ASTROLOGER" | "ADMIN" — who conceived the offer. Drives copy in
  /// the chat header and on the transactions page.
  source             String    @default("ASTROLOGER")
  minutesPerSession  Int       @default(0)
  usesPerUser        Int       @default(1)
  ratePerMinuteAfter Float     @default(0)
  startDate          DateTime?
  endDate            DateTime?
  active             Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  astrologer   AstrologerAccount             @relation(fields: [astrologerId], references: [id])
  sessions     AstrologerChatSession[]
  usages       AstrologerFreeOfferUsage[]

  @@index([astrologerId])
  @@index([active])
}

/// Tracks how many times each user has consumed an astrologer's
/// free-minute offer. A `(offerId, userId)` unique constraint keeps
/// the math simple — we increment `usesConsumed` on each accept.
model AstrologerFreeOfferUsage {
  id             Int      @id @default(autoincrement())
  offerId        Int
  userId         Int
  usesConsumed   Int      @default(0)
  lastUsedAt     DateTime?
  createdAt      DateTime @default(now())

  offer AstrologerFreeOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  user  User                @relation(fields: [userId], references: [id])

  @@unique([offerId, userId])
  @@index([userId])
}

/// Post-session review a shopper must submit after any ENDED session.
/// Captures the star rating + free-text comment; FE blocks dismissing
/// the modal until submitted. One review per session (enforced by the
/// unique sessionId).
model AstrologerReview {
  id           Int      @id @default(autoincrement())
  sessionId    Int      @unique
  astrologerId Int
  userId       Int
  rating       Int
  comment      String?
  createdAt    DateTime @default(now())

  session      AstrologerChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  astrologer   AstrologerAccount     @relation(fields: [astrologerId], references: [id])
  user         User                  @relation(fields: [userId], references: [id])

  @@index([astrologerId])
  @@index([userId])
}

model AstrologerChatMessage {
  id         Int                   @id @default(autoincrement())
  sessionId  Int
  senderType String
  senderId   Int
  text       String?
  imageUrl   String?
  createdAt  DateTime              @default(now())

  session    AstrologerChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

enum ChatSessionStatus {
  PENDING
  ACTIVE
  PAUSED
  ENDED
  REJECTED
}

/// Direct support-style chat between an astrologer and the admin team.
/// One thread per astrologer (lookups by astrologerId alone), messages
/// store the sender kind so a single row schema serves both directions.
/// Deliberately decoupled from AstrologerChatSession (which is the
/// paid user↔astrologer consultation) — the two have nothing in common
/// except the word "chat".
/// Cross-audience notification feed for the Jyotish surface. A single
/// row represents one push to one recipient. `recipientType` routes to
/// either a specific astrologer (ASTROLOGER + recipientId) or the
/// admin team as a whole (ADMIN + null recipientId). `kind` is the
/// event category so the UI can pick an icon / colour; the human-
/// readable `title` + `body` are rendered as-is. Optional `link`
/// deep-links into the relevant page (edit-request detail, chat etc).
model JyotishNotification {
  id            Int      @id @default(autoincrement())
  recipientType String
  recipientId   Int?
  kind          String
  title         String
  body          String
  link          String?
  read          Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([recipientType, recipientId, read])
  @@index([createdAt])
}

model AdminAstrologerMessage {
  id           Int               @id @default(autoincrement())
  astrologerId Int
  /// "ASTROLOGER" when the message came from the astrologer; "ADMIN"
  /// otherwise. Kept as a plain string so we don't need a new enum.
  senderType   String
  /// User id (if admin) or astrologer id (echoed from astrologerId).
  /// Useful for audit + "last seen by" logic down the line.
  senderId     Int
  text         String
  readByAdmin  Boolean           @default(false)
  readByAstro  Boolean           @default(false)
  createdAt    DateTime          @default(now())

  astrologer   AstrologerAccount @relation(fields: [astrologerId], references: [id])

  @@index([astrologerId])
  @@index([createdAt])
}
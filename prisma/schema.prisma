model BangaloreIncreffMappingSKU {
  id           Int      @id @default(autoincrement())
  channelSku   String
  ourSku       String
  // Per-location override for the same channel SKU. `null` (the default)
  // means the mapping applies to every location that carries this
  // channelSku — one-click mapping for the common case. A non-null value
  // narrows the mapping to that specific Increff location code so an admin
  // can route the same channelSku to different internal SKUs per warehouse.
  locationCode String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // PostgreSQL unique indexes treat NULLs as distinct, so two NULL-location
  // rows for the same channelSku can theoretically coexist. The service
  // guards against that on write; this index still prevents duplicate
  // per-location overrides landing for the same (channelSku, locationCode).
  @@unique([channelSku, locationCode])
}


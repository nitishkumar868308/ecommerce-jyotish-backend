generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  password     String?
  role         String    @default("USER")
  createdAt    DateTime  @default(now())
  address      String?
  gender       Gender?
  phone        String?
  updatedAt    DateTime  @default(now()) @updatedAt
  profileImage String?
  city         String?
  country      String?
  pincode      String?
  state        String?
  provider     String    @default("LOCAL")
  walletBalance Float    @default(0)
  lastLoginAt  DateTime?
  addresses    Address[]
  carts        Cart[]
  orders       Orders[]
  walletTransactions WalletTransaction[]
  astrologerChatSessions AstrologerChatSession[]
  astrologerReviews AstrologerReview[]
  astrologerFreeOfferUsages AstrologerFreeOfferUsage[]
}

model WalletTransaction {
  id        Int      @id @default(autoincrement())
  userId    Int
  amount    Float
  type      String
  note      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Header {
  id        Int      @id @default(autoincrement())
  name      String
  active    Boolean  @default(true)
  deleted   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id            Int           @id @default(autoincrement())
  name          String
  active        Boolean       @default(true)
  deleted       Int           @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  image         String?
  platform      String[]      @default([])
  hsn           String?
  countryTaxes  CountryTax[]
  products      Product[]
  subcategories Subcategory[]
  states        State[]       @relation("CategoryStates")
}

model Subcategory {
  id         Int       @id @default(autoincrement())
  name       String
  categoryId Int
  image      String?
  active     Boolean   @default(true)
  deleted    Int       @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  offerId    Int?
  platform   String[]  @default([])
  products   Product[]
  category   Category  @relation(fields: [categoryId], references: [id])
  states     State[]   @relation("SubcategoryStates")
}

model Product {
  id                  String             @id @default(cuid())
  name                String
  subcategoryId       Int
  sku                 String             @unique
  description         String?
  active              Boolean            @default(true)
  deleted             Int                @default(0)
  slug                String?            @unique
  metaTitle           String?
  metaDescription     String?
  keywords            String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  color               String[]           @default([])
  price               String?
  size                String[]           @default([])
  stock               String?
  categoryId          Int?
  short               String?
  offerId             Int?
  otherCountriesPrice String?
  image               String[]
  isDefault           Json?
  bulkPrice           String?
  minQuantity         String?
  /// Multi-tier volume pricing: [{ qty: number, unitPrice: number }]. When a
  /// user crosses a tier's qty threshold, that tier's unitPrice overrides the
  /// normal price (and any active offer stops applying — offer wins below the
  /// bulk threshold, bulk wins above it).
  bulkPricingTiers    Json?
  barCode             String?
  MRP                 String?
  platform            String[]           @default([])
  dimension           Json?
  /// Attribute names that should be IGNORED when grouping cart lines for
  /// offer/bulk eligibility. e.g. ["Color"] means two lines differing only in
  /// Color count as the same group and share offer/bulk thresholds.
  offerIgnoreAttributes String[]         @default([])
  marketLinks         MarketLink[]
  category            Category?          @relation(fields: [categoryId], references: [id])
  primaryOffer        Offer?             @relation("PrimaryOffer", fields: [offerId], references: [id])
  subcategory         Subcategory        @relation(fields: [subcategoryId], references: [id])
  variations          ProductVariation[]
  offers              Offer[]            @relation("ProductOffers")
  tags                Tag[]              @relation("ProductTags")
}

model ProductVariation {
  id                  String   @id @default(cuid())
  productId           String
  variationName       String
  sku                 String   @unique
  price               String?
  stock               String?
  description         String?
  active              Boolean  @default(true)
  deleted             Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  name                String?
  offerId             Int?
  otherCountriesPrice String?
  image               String[]
  short               String?
  bulkPrice           String?
  minQuantity         String?
  bulkPricingTiers    Json?
  /// Which attribute values this variation represents, e.g.
  ///   [{ "name": "Color", "value": "Red" }, { "name": "Size", "value": "M" }]
  /// Stored verbatim so the edit UI can restore the chips without re-joining
  /// against a normalised attribute-selection table.
  attributeCombo      Json?
  barCode             String?
  MRP                 String?
  dimension           Json?
  /// Admin-controlled order for the storefront variation picker. Persisted
  /// from the drag-and-drop reorder in the product form — index in the
  /// array at save-time becomes this column, so `orderBy: { sortOrder }`
  /// on read gives the exact layout the admin set.
  sortOrder           Int      @default(0)
  offer               Offer?   @relation("OfferToVariation", fields: [offerId], references: [id])
  product             Product  @relation(fields: [productId], references: [id])
  tags                Tag[]    @relation("VariationTags")
}

model Attribute {
  id        Int      @id @default(autoincrement())
  name      String
  values    String[]
  active    Boolean  @default(true)
  deleted   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Offer {
  id                Int                @id @default(autoincrement())
  name              String
  discountType      String
  discountValue     Json
  type              Json
  description       String?
  active            Boolean            @default(true)
  deleted           Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  primaryProducts   Product[]          @relation("PrimaryOffer")
  productVariations ProductVariation[] @relation("OfferToVariation")
  products          Product[]          @relation("ProductOffers")
}

model CountryPricing {
  id             Int      @id @default(autoincrement())
  country        String
  code           String   @unique
  multiplier     Float
  currency       String
  active         Boolean  @default(true)
  deleted        Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  currencySymbol String?
  conversionRate Float?
}

/// Cart stores only raw user intent (what they picked + how many). All
/// computed values (offer/bulk/price/currency) are derived server-side at
/// read time via CartService so the client can never tamper with them.
model Cart {
  id               String   @id @default(uuid())
  userId           Int?
  productId        String
  variationId      String?
  quantity         Int
  /// Free-form attribute map snapshot from when the item was added (e.g.
  /// { "Color": "Red", "Form": "Pack of 2" }). Used for display + offer
  /// grouping — full set kept, ignored-keys filtered out at compute time.
  attributes       Json
  is_buy           Boolean? @default(false)
  purchasePlatform String?  @default("website")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([productId])
}

model Address {
  id         String   @id @default(cuid())
  name       String
  mobile     String
  pincode    String
  address    String
  city       String
  state      String
  landmark   String?
  type       String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  userId     Int?
  customType String?
  isDefault  Boolean  @default(false)
  country    String?
  user       User?    @relation(fields: [userId], references: [id])
}

model Tag {
  id         Int                @id @default(autoincrement())
  name       String
  /// Auto-generated on create/update from `name`. Uniqueness is enforced so a
  /// storefront route never collides on two tags sharing a slug.
  slug       String             @unique
  active     Boolean            @default(true)
  image      String?
  deleted    Boolean            @default(false)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  products   Product[]          @relation("ProductTags")
  variations ProductVariation[] @relation("VariationTags")
}

model MarketLink {
  id          String   @id @default(cuid())
  countryName String
  countryCode String
  name        String
  url         String
  deleted     Boolean  @default(false)
  productId   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  product     Product? @relation(fields: [productId], references: [id])
}

model CountryTax {
  id          Int      @id @default(autoincrement())
  country     String
  categoryId  Int
  generalTax  Float?
  gstTax      Float?
  active      Boolean  @default(true)
  deleted     Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  type        String?
  countryCode String?
  category    Category @relation(fields: [categoryId], references: [id])
}

model VideoStory {
  id        Int      @id @default(autoincrement())
  title     String
  url       String
  active    Boolean  @default(true)
  deleted   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactMessage {
  id           Int            @id @default(autoincrement())
  name         String
  email        String
  subject      String?
  message      String
  isDeleted    Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  platform     String         @default("website")
  readByAdmin  Boolean        @default(false)
  readByUser   Boolean        @default(true)
  isRegistered Boolean        @default(false)
  replies      MessageReply[]
}

model MessageReply {
  id               Int            @id @default(autoincrement())
  contactMessageId Int
  sender           String
  message          String
  createdAt        DateTime       @default(now())
  readByAdmin      Boolean        @default(false)
  readByUser       Boolean        @default(false)
  contactMessage   ContactMessage @relation(fields: [contactMessageId], references: [id])
}

model Orders {
  id                 Int                 @id @default(autoincrement())
  userId             Int?
  userName           String?
  userEmail          String?
  userPhone          String?
  shippingName       String?
  shippingPhone      String?
  shippingAddress    String?
  shippingCity       String?
  shippingState      String?
  shippingPincode    String?
  shippingCountry    String?
  billingName        String?
  billingPhone       String?
  billingAddress     String?
  billingCity        String?
  billingState       String?
  billingPincode     String?
  billingCountry     String?
  subtotal           Float?
  shippingCharges    Float?
  taxAmount          Float?
  discountAmount     Float?
  totalAmount        Float?
  /// Snapshot of the currency the customer was shown + paid in. Everything
  /// the user sees (invoice, emails, dashboards) uses this — never recompute.
  paymentCurrency    String?
  currencySymbol     String?
  /// INR→paymentCurrency multiplier at order time. Lets us reconcile to INR
  /// ledger without a second conversion lookup later.
  conversionRate     Float?
  baseTotalAmount    Float?
  paymentMethod      String?
  /// PayU (or other gateway) transaction id captured on successful callback.
  paymentTxnId       String?
  paymentPaidAt      DateTime?
  /// Raw failure / cancellation reason echoed by PayU. Useful when the
  /// admin needs to explain a declined payment to the shopper.
  paymentError       String?
  status             OrderStatus         @default(PENDING)
  paymentStatus      PaymentStatus       @default(PENDING)
  active             Boolean             @default(true)
  deleted            Int                 @default(0)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  orderNumber        String?             @unique
  orderBy            String?
  donationAmount     Float?
  donationCampaignId Int?
  note               String?
  promoCode          String?
  promoDiscount      Float?
  trackingLink       String?
  /// Invoice fields are only populated once payment is confirmed. The
  /// sequence is atomically incremented via the InvoiceSequence table.
  invoiceDate        DateTime?
  invoiceNumber      String?             @unique
  fiscalYear         Int?
  invoiceSeq         Int?
  locationCode       String?
  user               User?               @relation(fields: [userId], references: [id])
  orderItems         OrderItem[]
  adjustments        order_adjustments[]

  @@index([userId])
  @@index([fiscalYear, invoiceSeq])
}

/// Line-item snapshot. Everything needed to render an invoice / admin view
/// without joining back to Product or Offer (those can change post-order).
model OrderItem {
  id                   Int      @id @default(autoincrement())
  orderId              Int
  productId            String
  variationId          String?
  productName          String
  variationName        String?
  sku                  String?
  fnsku                String?
  barCode              String?
  image                String?

  quantity             Int
  paidQty              Int
  freeQty              Int      @default(0)

  originalPrice        Float
  pricePerItem         Float
  bulkApplied          Boolean  @default(false)
  bulkMinQty           Int?
  bulkPrice            Float?

  offerApplied         Boolean  @default(false)
  offerId              Int?
  offerName            String?
  productOfferDiscount Float?

  savedAmount          Float    @default(0)
  /// Offer/bulk grouping key used at order-create time (productId +
  /// attributes-minus-ignored). Kept so admin can see which lines shared an
  /// offer even though they had different colours etc.
  groupKey             String?
  currency             String?
  currencySymbol       String?
  attributes           Json?
  createdAt            DateTime @default(now())

  order                Orders   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([productId])
}

/// Single row per fiscal year. Invoice generation does an atomic
/// `UPDATE ... SET lastSeq = lastSeq + 1 RETURNING lastSeq` inside a
/// transaction so two concurrent payments can't collide on the same number.
model InvoiceSequence {
  fiscalYear Int      @id
  lastSeq    Int      @default(0)
  updatedAt  DateTime @updatedAt
}

model ShippingPricing {
  id             String   @id @default(uuid())
  name           String
  price          Float
  active         Boolean  @default(true)
  deleted        Int      @default(0)
  createdAt      DateTime @default(now())
  description    String?
  code           String?
  country        String?
  currency       String?
  currencySymbol String?
  type           String?
}

model State {
  id            Int           @id @default(autoincrement())
  // Display values (kept denormalised so downstream consumers —
  // banners/categories — don't need to join on Country/StateCountry/CityCountry).
  countryId     Int?
  countryName   String?
  // `name` holds the state's display name; `stateRefId` points at the source
  // StateCountry row used to pick it.
  stateRefId    Int?
  name          String
  cityRefId     Int?
  city          String?
  active        Boolean       @default(true)
  deleted       Int           @default(0)
  createdAt     DateTime      @default(now())
  banners       BannerState[]
  categories    Category[]    @relation("CategoryStates")
  subcategories Subcategory[] @relation("SubcategoryStates")
}

model WareHouse {
  id                     Int         @id @default(autoincrement())
  state                  String
  /// Optional reference to the Location master (State table) row for this
  /// warehouse's city — lets us surface accurate city + state without extra
  /// joins while keeping the denormalised strings for backward compat.
  cityRefId              Int?
  city                   String?
  name                   String
  address                String
  code                   String
  pincode                String
  deleted                Boolean     @default(false)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  active                 Boolean     @default(true)
  contact                String?
  fulfillmentWarehouseId Int?
  fulfillmentWarehouse   WareHouse?  @relation("WarehouseSelfRelation", fields: [fulfillmentWarehouseId], references: [id])
  fulfilledWarehouses    WareHouse[] @relation("WarehouseSelfRelation")
}

model WarehouseTransfer {
  id            Int      @id @default(autoincrement())
  productId     String
  variationId   String?
  productName   String
  variationName String?
  price         String
  MRP           String
  FNSKU         String
  entries       Json
  active        Boolean  @default(true)
  deleted       Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  image         String?
  status        String   @default("pending")
  sku           String?
}

model WarehouseDispatch {
  id           Int      @id @default(autoincrement())
  entries      Json
  totalUnits   Int
  totalFNSKU   Int
  status       String   @default("pending")
  active       Boolean  @default(true)
  deleted      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  dimensions   Json?
  shippingId   String?
  trackingId   String?
  trackingLink String?
}

model DelhiWarehouseStock {
  id           Int      @id @default(autoincrement())
  dispatchId   Int
  shippingId   String
  trackingId   String?
  trackingLink String?
  status       String   @default("accepted")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  active       Boolean  @default(true)
  deleted      Boolean  @default(false)
  productId    String
  stock        Int
  variationId  String
  warehouseId  Int

  @@unique([dispatchId, productId, variationId])
}

model ChatMessage {
  id           Int      @id @default(autoincrement())
  text         String
  deleted      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orderId      Int
  receiverRole String
  senderRole   String
  receiverId   Int
  senderId     Int
}

model Banner {
  id        Int             @id @default(autoincrement())
  text      String?
  image     String?
  platform  String[]
  active    Boolean         @default(true)
  deleted   Boolean         @default(false)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  link      String?
  countries BannerCountry[]
  states    BannerState[]
}

model BannerCountry {
  id          Int    @id @default(autoincrement())
  bannerId    Int
  countryCode String
  position    Int
  banner      Banner @relation(fields: [bannerId], references: [id], onDelete: Cascade)

  @@unique([bannerId, countryCode])
}

model BannerState {
  id       Int    @id @default(autoincrement())
  bannerId Int
  stateId  Int
  position Int
  banner   Banner @relation(fields: [bannerId], references: [id], onDelete: Cascade)
  state    State  @relation(fields: [stateId], references: [id])

  @@unique([bannerId, stateId])
}

model PromoCode {
  id            Int               @id @default(autoincrement())
  code          String            @unique
  active        Boolean           @default(true)
  deleted       Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  appliesTo     PromoAppliesTo
  discountType  PromoDiscountType
  discountValue Float
  usageLimit    Int?
  usedCount     Int               @default(0)
  validFrom     DateTime
  validTill     DateTime
  eligibleUsers Json?
  users         PromoUser[]
}

model PromoUser {
  id             Int       @id @default(autoincrement())
  promoId        Int
  userId         Int
  usedCount      Int       @default(1)
  orderId        Int
  discountAmount Float?
  subtotal       Float?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime? @updatedAt
  promo          PromoCode @relation(fields: [promoId], references: [id])

  @@unique([promoId, orderId])
}

model DonationCampaign {
  id            Int            @id @default(autoincrement())
  title         String
  description   String
  amounts       Float[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  active        Boolean        @default(true)
  userDonations UserDonation[]
}

model UserDonation {
  id                 Int              @id @default(autoincrement())
  userName           String
  amount             Float
  donatedAt          DateTime         @default(now())
  donationCampaignId Int
  orderId            Int?
  userId             Int?
  donationCampaign   DonationCampaign @relation(fields: [donationCampaignId], references: [id])
}

model Reviews {
  id        Int      @id @default(autoincrement())
  userId    Int
  userName  String
  comment   String
  rating    Int
  status    String   @default("pending")
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  productId String?
}

model BangaloreIncreffOrder {
  id           Int      @id @default(autoincrement())
  dispatchId   Int
  orderCode    String
  locationCode String
  payload      Json
  response     Json
  createdAt    DateTime @default(now())
}

model Duration {
  id            Int               @id @default(autoincrement())
  minutes       Int
  description   String?
  active        Boolean           @default(true)
  deleted       Boolean           @default(false)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  servicePrices ServiceDuration[]
}

model Service {
  id        Int      @id @default(autoincrement())
  title     String
  shortDesc String?
  longDesc  String?
  image     String?
  active    Boolean  @default(true)
  deleted   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceDuration {
  id         Int      @id @default(autoincrement())
  durationId Int
  price      Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  duration   Duration @relation(fields: [durationId], references: [id])
}

model Astrologer {
  id           Int                  @id @default(autoincrement())
  fullName     String
  displayName  String?
  profileImage String?
  phone        String?
  description  String?
  active       Boolean              @default(true)
  deleted      Boolean              @default(false)
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  service      String?
  specialty    String?
  userId       Int?
  documents    AstrologerDocument[]
}

model AstrologerDocument {
  id           Int        @id @default(autoincrement())
  astrologerId Int
  fileUrl      String
  createdAt    DateTime   @default(now())
  astrologer   Astrologer @relation(fields: [astrologerId], references: [id])
}

model Blog {
  id          Int      @id @default(autoincrement())
  title       String
  slug        String   @unique
  authorName  String
  category    String
  description String
  excerpt     String?
  image       String?
  isPublished Boolean  @default(false)
  active      Boolean  @default(true)
  deleted     Boolean  @default(false)
  views       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  authorImage String?
  readTime    Int?
}

model BlogReviews {
  id        Int              @id @default(autoincrement())
  userId    Int
  userName  String
  blogId    Int
  comment   String
  rating    Int
  status    ReviewStatusBlog @default(pending)
  active    Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@unique([userId, blogId])
}

model PasswordReset {
  id        Int      @id @default(autoincrement())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())
}

model order_adjustments {
  id             Int              @id @default(autoincrement())
  orderId        Int
  adjustmentType AdjustmentType
  impact         AdjustmentImpact
  amount         Decimal          @db.Decimal(12, 2)
  reason         String?          @db.VarChar(255)
  status         AdjustmentStatus @default(PENDING)
  paymentTxnId   String?          @unique
  paidAt         DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  isManual       Boolean          @default(false)
  manualType     String?          @db.VarChar(200)
  expiresAt      DateTime?
  order          Orders           @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model AstrologerAccount {
  id                Int                              @id @default(autoincrement())
  fullName          String
  email             String                           @unique
  gender            Gender?
  createdAt         DateTime                         @default(now())
  updatedAt         DateTime                         @updatedAt
  countryCode       String
  phone             String                           @unique
  phoneLocal        String
  isActive          Boolean                          @default(false)
  isApproved        Boolean                          @default(false)
  bio               String?
  displayName       String?
  isRejected        Boolean                          @default(false)
  rejectReason      String?
  revenueAdmin      Float?
  revenueAstrologer Float?
  gst               Float?
  isTop             Boolean  @default(false)
  topRank           Int?
  password          String?
  credentialsSent   Boolean  @default(false)
  isBusy            Boolean  @default(false)
  /// Astrologer-controlled availability switch (distinct from admin's
  /// isActive). When false, public listings + booking flows hide the
  /// astrologer even if they're approved + active. Toggled from the
  /// astrologer dashboard's online/offline pill.
  isOnline          Boolean  @default(false)
  profile           AstrologerProfile?
  services          AstrologerService[]
  documents         AstrologerVerificationDocument[]
  certificates      Certificate[]
  penalties AstrologerPenalty[]
  extraDocuments AstrologerExtraDocument[]
  editRequests ProfileEditRequest[]
  adBookings AdBooking[]
  chatSessions AstrologerChatSession[]
  adminMessages AdminAstrologerMessage[]

  recipientId   Int?     // null for ADMIN broadcast
  type          String   // "CHAT_REQUEST" | "FREE_OFFER" | "PROFILE_APPROVED" | ...
  title         String
  body          String?
  link          String?  // in-app deep link
  read          Boolean  @default(false)
  readAt        DateTime?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([recipientType, recipientId, read, createdAt])
}

